# SIP backend (FastAPI)
VITE_API_URL=http://localhost:8000

# Mapbox Geocoding API — address autocomplete in search bar
VITE_MAPBOX_ACCESS_TOKEN=
# Optional: bias results (lon,lat). Example NYC: -73.9857,40.7484
# VITE_MAPBOX_PROXIMITY=-73.9857,40.7484
# Optional: bounding box west,south,east,north. Example NYC metro:
# VITE_MAPBOX_BBOX=-74.2591,40.4774,-73.7004,40.9176
